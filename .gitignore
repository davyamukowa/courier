# This repo is scoped ONLY to the two synced modules (see CLAUDE.md sync setup).
# Whitelist approach: ignore everything, then re-include what we want.
/*
!modules/
modules/*
!modules/courier_goshipping/
!modules/shopify_connector/
!.cpanel.yml
!deploy.php
!.gitignore

# Common junk inside the whitelisted modules
**/.DS_Store
**/Thumbs.db
