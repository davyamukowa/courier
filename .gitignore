# This repo syncs the whole modules/ directory (see CLAUDE.md sync setup),
# plus the deploy config files at the root. Everything else at the repo
# root (application/, assets/, vendor/, etc.) stays out of this repo.
/*
!modules/
!.cpanel.yml
!.gitignore

# Don't track the standalone module .zip bundles sitting next to each
# module folder (courier_goshipping.zip, fleet.zip, xetuu_hr.zip, etc.)
modules/*.zip

# Common junk inside the whitelisted modules
**/.DS_Store
**/Thumbs.db
